generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  nom       String
  role      String   @default("OPERATEUR")
  // permissions: Json column managed via auto-migration (ALTER TABLE)
  createdAt DateTime @default(now())
}

model Commentaire {
  id         String   @id @default(cuid())
  commandeId String
  auteur     String
  texte      String
  createdAt  DateTime @default(now())
  commande   Commande @relation(fields: [commandeId], references: [id], onDelete: Cascade)
}

model Commande {
  id                      String         @id @default(cuid())
  commentaires            Commentaire[]
  num_commande            String
  client                  String
  ref_chantier            String?
  zone                    String   @default("SIAL")
  priorite                String   @default("normale")
  semaine_theorique       String?
  semaine_atteignable     String?
  date_alu                String?
  date_pvc                String?
  date_accessoires        String?
  date_panneau_porte      String?
  date_volet_roulant      String?
  date_livraison_souhaitee String?
  type                    String
  quantite                Int
  hsTemps                 Json?
  lignes                  Json?
  vitrages                Json?
  aucun_vitrage           Boolean  @default(false)
  aucune_menuiserie       Boolean  @default(false)
  cmd_alu_passee          Boolean  @default(false)
  cmd_pvc_passee          Boolean  @default(false)
  cmd_accessoires_passee  Boolean  @default(false)
  cmd_panneau_passee      Boolean  @default(false)
  cmd_volet_passee        Boolean  @default(false)
  cmd_alu_necessaire      Boolean  @default(false)
  cmd_pvc_necessaire      Boolean  @default(false)
  cmd_accessoires_necessaire Boolean @default(false)
  cmd_panneau_necessaire  Boolean  @default(false)
  cmd_volet_necessaire    Boolean  @default(false)
  avancement              Int      @default(0)
  statut                  String   @default("en_attente")
  transporteur            String?
  etape_coupe_ok          Boolean  @default(false)
  etape_montage_ok        Boolean  @default(false)
  etape_vitrage_ok        Boolean  @default(false)
  etape_palette_ok        Boolean  @default(false)
  etape_coupe_date        String?
  etape_montage_date      String?
  etape_vitrage_date      String?
  etape_palette_date      String?
  notes                   String?
  type_commande           String?
  atelier                 String   @default("SIAL")
  montant_ht              Float?
  acompte_recu              Boolean  @default(false)
  acompte_montant           Float?
  acompte_date              String?
  reliquat_alu              Boolean  @default(false)
  reliquat_alu_desc         String?
  reliquat_alu_date         String?
  reliquat_pvc              Boolean  @default(false)
  reliquat_pvc_desc         String?
  reliquat_pvc_date         String?
  reliquat_accessoires      Boolean  @default(false)
  reliquat_accessoires_desc String?
  reliquat_accessoires_date String?
  nb_livraisons             Int      @default(1)
  dates_livraisons          Json?
  semaine_coupe           String?
  semaine_montage         String?
  semaine_vitrage         String?
  semaine_logistique      String?
  semaine_isula           String?
  // ── Phase 0-A : champs saisie exhaustive ─────────────────────────────
  /// YYYY-MM-DD — RDV poseur ferme. Prioritaire sur date_livraison_souhaitee.
  pose_chantier_date          String?
  /// Si vrai, toutes les phases doivent finir dans la même semaine calendaire.
  regroupement_camion         Boolean  @default(true)
  /// Si vrai, on autorise plusieurs vagues de livraison (gros chantier).
  chantier_split_autorise     Boolean  @default(false)
  /// Texte libre — ex "test étanchéité au jet d'eau, CEKAL renforcé".
  controle_qualite_specifique String?
  /// Notes pose (accès, étage, contraintes site).
  notes_pose                  String?
  /// "bas" | "moyen" | "haut" — pondération du chantier dans le critique-ratio.
  risque_perso                String   @default("bas")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model LigneVitrage {
  id                     String   @id @default(cuid())
  commandeId             String
  num_commande           String?
  client                 String?
  ref_chantier           String?
  composition            String?
  quantite               Int      @default(1)
  position               String?
  largeur_mm             Float?
  hauteur_mm             Float?
  epaisseur_intercalaire String?
  coloris_intercalaire   String?
  largeur_we             Float?
  hauteur_we             Float?
  perimetre_we           Float?
  date_fabrication       String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model ControleQualite {
  date      String   @id
  data      Json
  updatedAt DateTime @updatedAt
}

model PlanningIsula {
  semaine   String   @id
  plan      Json
  valide    Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

model StockTampon {
  id      String @id
  actuel  Float  @default(0)
  updatedAt DateTime @updatedAt
}

model PlanningRH {
  semaine   String   @id
  plan      Json
  valide    Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

model Backup {
  id        String   @id @default(cuid())
  data      Json
  createdAt DateTime @default(now())
}

model PlanningPoste {
  semaine   String   @id
  plan      Json
  updatedAt DateTime @updatedAt
}

model Tache {
  id               String   @id @default(cuid())
  nom              String
  temps_unitaire   Float
  unite            String
  categorie        String   @default("production")
  parallelisable   Boolean  @default(false)
  competences      Json     @default("[]")
  ordre            Int      @default(0)
  actif            Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model CompetenceOperateur {
  id          String   @id @default(cuid())
  operateurId String
  tacheId     String
  priorite    Int      @default(1)
  updatedAt   DateTime @updatedAt

  @@unique([operateurId, tacheId])
}

model AvancementJournalier {
  id          String   @id @default(cuid())
  date        String
  operateur   String
  tacheId     String
  commandeId  String?
  quantite    Float
  notes       String?
  createdAt   DateTime @default(now())
}

model SemaineValidee {
  semaine     String   @id
  valide      Boolean  @default(false)
  validePar   String?
  valideAt    DateTime?
  plan        Json     @default("{}")
  updatedAt   DateTime @updatedAt
}

model TacheRituelle {
  id       String  @id @default(cuid())
  label    String
  fixe     Boolean @default(false)
  visible  Boolean @default(true)
  ordre    Int     @default(0)
}

model MembreEquipe {
  id         String @id @default(cuid())
  nom        String
  naissance  String @default("")
  actif      Boolean @default(true)
}

// ═══════════════════════════════════════════════════════════════════════════
// NOUVEAU PLANNING INDUSTRIEL — Modèles spec section 1
// ═══════════════════════════════════════════════════════════════════════════

model Operator {
  id              String            @id @default(cuid())
  name            String
  weekHours       Float
  posts           String[]
  workingDays     Int[]             @default([0, 1, 2, 3, 4])
  notes           String?
  active          Boolean           @default(true)
  /// Horaires détaillés par jour de la semaine (JSON).
  /// Format : { "Mon": [{from: "08:00", to: "12:00"}, {from: "13:00", to: "17:00"}], ... }
  /// Si null, on utilise la convention par défaut basée sur weekHours.
  defaultSchedule Json?
  /// Date de naissance (ISO YYYY-MM-DD) pour anniversaires.
  naissance       String?
  absences        OperatorAbsence[]
  taskAssignments TaskAssignment[]
  scheduleSlots   ScheduleSlot[]
  skills          OperatorSkill[]
}

model OperatorSkill {
  id              String    @id @default(cuid())
  operatorId      String
  workPostId      String?
  menuiserieType  String?
  level           Int       @default(0)
  updatedAt       DateTime  @updatedAt
  updatedBy       String?
  operator        Operator  @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  workPost        WorkPost? @relation(fields: [workPostId], references: [id])

  @@unique([operatorId, workPostId, menuiserieType])
}

model OperatorAbsence {
  id         String   @id @default(cuid())
  operatorId String
  date       DateTime
  reason     String?
  operator   Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)
}

model WorkPost {
  id               String           @id
  label            String
  shortLabel       String?          // libellé court pour les vues compactes (ex: "Coupe LMT")
  atelier          Atelier
  capacityMinDay   Int
  /// Phase de fabrication : coupe / montage / vitrage / isula / logistique / autre
  phase            String?
  /// Nombre maximum d'opérateurs simultanés (1 = exclusif, null = pas de limite)
  maxOperators     Int?
  /// Tampon en minutes après cette étape avant la suivante (par défaut 240 = 4h)
  tamponMinAfter   Int?
  /// Couleur d'affichage (hex). Pour cohérence des vues.
  color            String?
  /// Visible par défaut dans les vues utilisateur (Aujourd'hui, PlanningAffectations)
  visible          Boolean          @default(true)
  /// Ordre d'affichage dans la phase
  sortOrder        Int              @default(0)
  /// Planification autonome : nombre d'opérateurs utiles max (au-delà, gêne)
  parallelism      Int?             @default(1)
  /// Courbe d'efficacité — gain de vitesse selon nb_ops (JSON: number[]).
  /// Ex: [1.0, 1.8, 2.4] = 1op→×1, 2ops→×1.8, 3ops→×2.4
  parallelGain     Json?
  /// Si vrai, 1 seul opérateur du début à la fin (qualité, sur-mesure)
  monolithic       Boolean          @default(false)
  defaultOperators String[]
  tasks            ProductionTask[]
  skills           OperatorSkill[]
}

enum Atelier {
  SIAL
  ISULA
}

model Order {
  id           String        @id @default(cuid())
  refProF2     String        @unique
  refChantier  String
  clientName   String
  deliveryDate DateTime
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  status       OrderStatus   @default(A_LANCER)
  items        FabItem[]
  bufferStocks BufferStock[]
  notes        String?
}

enum OrderStatus {
  A_LANCER
  EN_COURS
  ATTENTE_VITRAGE
  ATTENTE_IGU
  PRET_LIVRAISON
  LIVRE
  SUSPENDU
}

model FabItem {
  id             String         @id @default(cuid())
  orderId        String
  menuiserieType MenuiserieType
  quantity       Int
  label          String
  isSpecial      Boolean        @default(false)
  specialType    SpecialType?
  matiere        Matiere
  widthMm        Int?
  heightMm       Int?
  fabOrder       Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  tasks          ProductionTask[]
  qcChecks       QCCheck[]
}

enum MenuiserieType {
  OB1_PVC
  OB2_PVC
  OF1_PVC
  OF2_PVC
  FIXE_PVC
  PF1_PVC
  PF2_PVC
  OB1_ALU
  OB2_ALU
  OF1_ALU
  OF2_ALU
  FIXE_ALU
  PF1_ALU
  PF2_ALU
  P1_ALU
  P2_ALU
  C2V2R
  C3V3R
  C4V4R
  C4V2R
  G1V1R
  G2V1R
  G2V2R
  G3V3R
  G4V2R
  HORS_STANDARD
  INTERVENTION_CHANTIER
}

enum SpecialType {
  COULISSANT_GRAND_FORMAT
  GALANDAGE_GRAND_FORMAT
  HORS_NORME
  INTERVENTION
}

enum Matiere {
  ALU
  PVC
  ALU_PVC
}

model ProductionTask {
  id               String         @id @default(cuid())
  fabItemId        String
  workPostId       String
  label            String
  estimatedMinutes Int
  actualMinutes    Int?
  status           TaskStatus     @default(PENDING)
  scheduledDate    DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  blockedReason    String?
  sortOrder        Int            @map("sort_order")
  isBlocking       Boolean        @default(false)
  /// Phase 0-B / 1-A : IDs des tasks qui doivent finir avant celle-ci.
  predecessorIds   String[]       @default([])
  /// Phase 0-B : borne basse (jalons matière, fin laquage, etc.).
  earliestStart    DateTime?
  /// Phase 0-B : calculé par backward (deadline - tampons aval).
  latestFinish     DateTime?
  /// Phase 0-B : mis à jour quand l'algo pose la task.
  scheduledStart   DateTime?
  scheduledEnd     DateTime?
  assignments      TaskAssignment[]
  qcChecks         QCCheck[]
  scheduleSlots    ScheduleSlot[]
  fabItem          FabItem        @relation(fields: [fabItemId], references: [id], onDelete: Cascade)
  workPost         WorkPost       @relation(fields: [workPostId], references: [id])
}

/// Phase 0-B : un créneau atomique (½ journée) où un opérateur travaille
/// sur une ProductionTask. Source de vérité pour la grille de planning.
model ScheduleSlot {
  id          String         @id @default(cuid())
  taskId      String
  operatorId  String
  date        DateTime       // jour du créneau (00:00 UTC)
  halfDay     String         // "AM" | "PM"
  minutes     Int            // minutes effectives (≤ 240)
  createdAt   DateTime       @default(now())
  task        ProductionTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  operator    Operator       @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@index([date, halfDay])
  @@unique([taskId, operatorId, date, halfDay])
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  BLOCKED
  SKIPPED
}

model TaskAssignment {
  id         String         @id @default(cuid())
  taskId     String
  operatorId String
  task       ProductionTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  operator   Operator       @relation(fields: [operatorId], references: [id], onDelete: Cascade)
}

model QCCheck {
  id          String          @id @default(cuid())
  fabItemId   String
  taskId      String?
  qcRef       String
  label       String
  result      QCResult?
  value       String?
  checkedAt   DateTime?
  checkedBy   String?
  actionTaken String?
  fabItem     FabItem         @relation(fields: [fabItemId], references: [id], onDelete: Cascade)
  task        ProductionTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)
}

enum QCResult {
  OK
  NOK
  REPRISE
  REBUT
}

model BufferStock {
  id        String     @id @default(cuid())
  orderId   String?
  type      BufferType
  quantity  Float      @default(0)
  unit      String
  updatedAt DateTime   @updatedAt
  fabOrder  Order?     @relation(fields: [orderId], references: [id])
}

enum BufferType {
  PROFILES_COUPES
  VITRAGES_ISULA
  OUVRANTS_VITRES
  ACCESSOIRES_PREPARES
  PROFILES_BRUTS
  VERRE_BRUT_ISULA
}

model NonConformity {
  id          String     @id @default(cuid())
  fabItemId   String
  qcRef       String?
  description String
  severity    NCSeverity
  status      NCStatus   @default(DETECTED)
  cause       String?
  action      String?
  resolvedAt  DateTime?
  createdAt   DateTime   @default(now())
}

enum NCSeverity {
  MINOR
  MAJOR
  BLOCKING
}

enum NCStatus {
  DETECTED
  IN_QUARANTINE
  UNDER_REPAIR
  RESOLVED
  SCRAPPED
}

model DayConfig {
  date      String   @id
  mode      String   @default("FRAPPES")
  updatedAt DateTime @updatedAt
}

// ── Assistant IA — Mémos, tâches, rappels créés par dictée/texte ──────────

model MemoAction {
  id          String   @id @default(cuid())
  auteur      String
  texte       String
  type        String   @default("memo")    // memo | tache | rappel | planning
  priorite    String   @default("normale") // normale | urgente | critique
  statut      String   @default("ouvert")  // ouvert | en_cours | fait | annule
  echeance    String?                       // date YYYY-MM-DD optionnelle
  assigneA    String?                       // opérateur assigné
  commandeId  String?                       // lien commande si applicable
  poste       String?                       // poste concerné si applicable
  metadata    Json?                         // données structurées supplémentaires
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
