generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  nom       String
  role      String   @default("OPERATEUR")
  createdAt DateTime @default(now())
}

model Commentaire {
  id         String   @id @default(cuid())
  commandeId String
  auteur     String
  texte      String
  createdAt  DateTime @default(now())
  commande   Commande @relation(fields: [commandeId], references: [id], onDelete: Cascade)
}

model Commande {
  id                      String         @id @default(cuid())
  commentaires            Commentaire[]
  num_commande            String
  client                  String
  ref_chantier            String?
  zone                    String   @default("SIAL")
  priorite                String   @default("normale")
  semaine_theorique       String?
  semaine_atteignable     String?
  date_alu                String?
  date_pvc                String?
  date_accessoires        String?
  date_panneau_porte      String?
  date_volet_roulant      String?
  date_livraison_souhaitee String?
  type                    String
  quantite                Int
  hsTemps                 Json?
  lignes                  Json?
  vitrages                Json?
  aucun_vitrage           Boolean  @default(false)
  cmd_alu_passee          Boolean  @default(false)
  cmd_pvc_passee          Boolean  @default(false)
  cmd_accessoires_passee  Boolean  @default(false)
  cmd_panneau_passee      Boolean  @default(false)
  cmd_volet_passee        Boolean  @default(false)
  cmd_alu_necessaire      Boolean  @default(false)
  cmd_pvc_necessaire      Boolean  @default(false)
  cmd_accessoires_necessaire Boolean @default(false)
  cmd_panneau_necessaire  Boolean  @default(false)
  cmd_volet_necessaire    Boolean  @default(false)
  avancement              Int      @default(0)
  statut                  String   @default("en_attente")
  transporteur            String?
  etape_coupe_ok          Boolean  @default(false)
  etape_montage_ok        Boolean  @default(false)
  etape_vitrage_ok        Boolean  @default(false)
  etape_palette_ok        Boolean  @default(false)
  notes                   String?
  type_commande           String?
  atelier                 String   @default("SIAL")
  montant_ht              Float?
  acompte_recu              Boolean  @default(false)
  acompte_montant           Float?
  acompte_date              String?
  reliquat_alu              Boolean  @default(false)
  reliquat_alu_desc         String?
  reliquat_alu_date         String?
  reliquat_pvc              Boolean  @default(false)
  reliquat_pvc_desc         String?
  reliquat_pvc_date         String?
  reliquat_accessoires      Boolean  @default(false)
  reliquat_accessoires_desc String?
  reliquat_accessoires_date String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model LigneVitrage {
  id                     String   @id @default(cuid())
  commandeId             String
  num_commande           String?
  client                 String?
  ref_chantier           String?
  composition            String?
  quantite               Int      @default(1)
  position               String?
  largeur_mm             Float?
  hauteur_mm             Float?
  epaisseur_intercalaire String?
  coloris_intercalaire   String?
  largeur_we             Float?
  hauteur_we             Float?
  perimetre_we           Float?
  date_fabrication       String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model ControleQualite {
  date      String   @id
  data      Json
  updatedAt DateTime @updatedAt
}

model PlanningIsula {
  semaine   String   @id
  plan      Json
  valide    Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

model StockTampon {
  id      String @id
  actuel  Float  @default(0)
  updatedAt DateTime @updatedAt
}

model PlanningRH {
  semaine   String   @id
  plan      Json
  valide    Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

model Backup {
  id        String   @id @default(cuid())
  data      Json
  createdAt DateTime @default(now())
}

model Tache {
  id               String   @id @default(cuid())
  nom              String
  temps_unitaire   Float
  unite            String
  categorie        String   @default("production")
  parallelisable   Boolean  @default(false)
  competences      Json     @default("[]")
  ordre            Int      @default(0)
  actif            Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model CompetenceOperateur {
  id          String   @id @default(cuid())
  operateurId String
  tacheId     String
  priorite    Int      @default(1)
  updatedAt   DateTime @updatedAt

  @@unique([operateurId, tacheId])
}

model AvancementJournalier {
  id          String   @id @default(cuid())
  date        String
  operateur   String
  tacheId     String
  commandeId  String?
  quantite    Float
  notes       String?
  createdAt   DateTime @default(now())
}

model SemaineValidee {
  semaine     String   @id
  valide      Boolean  @default(false)
  validePar   String?
  valideAt    DateTime?
  plan        Json     @default("{}")
  updatedAt   DateTime @updatedAt
}

model TacheRituelle {
  id       String  @id @default(cuid())
  label    String
  fixe     Boolean @default(false)
  visible  Boolean @default(true)
  ordre    Int     @default(0)
}

model MembreEquipe {
  id         String @id @default(cuid())
  nom        String
  naissance  String @default("")
  actif      Boolean @default(true)
}
